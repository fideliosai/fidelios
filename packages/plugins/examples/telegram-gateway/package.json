{
  "name": "@fideliosai/plugin-telegram-gateway",
  "version": "0.1.0",
  "description": "FideliOS plugin that routes agent events to a Telegram supergroup and routes bot replies back as issue comments",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "fideliosPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
    "prebuild": "node ../../../../scripts/ensure-plugin-build-deps.mjs",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "pnpm --filter @fideliosai/plugin-sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@fideliosai/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3"
  }
}
